{
  "name": "ton-economic-watchers",
  "version": "0.1.0",
  "private": true,
  "description": "Telegram-native AI economic watcher MVP for TON assets using STON.fi data.",
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.json && vite build --config miniapp/vite.config.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "dev:bot": "tsx watch src/bot/index.ts",
    "dev:collector": "tsx watch src/jobs/collector.ts",
    "dev:scorer": "tsx watch src/jobs/scorer.ts",
    "dev:alerts": "tsx watch src/jobs/alerts.ts",
    "dev:server": "tsx watch src/server/index.ts",
    "dev:miniapp": "vite --host 0.0.0.0 --config miniapp/vite.config.ts",
    "run:collector": "tsx src/jobs/collector.ts --once",
    "run:scorer": "tsx src/jobs/scorer.ts --once",
    "run:alerts": "tsx src/jobs/alerts.ts --once",
    "health": "tsx src/jobs/health.ts",
    "start:bot": "node dist/bot/index.js",
    "start:collector": "node dist/jobs/collector.js",
    "start:scorer": "node dist/jobs/scorer.js",
    "start:alerts": "node dist/jobs/alerts.js",
    "start:server": "node dist/server/index.js",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:deploy": "prisma migrate deploy",
    "db:studio": "prisma studio"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "@ston-fi/api": "^0.32.0",
    "@ston-fi/sdk": "^2.7.0",
    "@tonconnect/ui-react": "^2.4.4",
    "@vitejs/plugin-react": "^6.0.2",
    "dotenv": "^16.4.7",
    "express": "^5.2.1",
    "grammy": "^1.33.0",
    "openai": "^4.77.0",
    "pino": "^9.5.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "vite": "^8.0.13",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^22.10.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "pino-pretty": "^13.0.0",
    "prisma": "^5.22.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^4.1.6"
  },
  "engines": {
    "node": ">=20.11"
  }
}
